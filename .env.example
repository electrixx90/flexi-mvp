PORT=3033
IOTA_NETWORK=testnet
IOTA_RPC_URL=https://api.testnet.iota.cafe

# Use one sponsor secret source:
IOTA_SPONSOR_SECRET_KEY=secret_key

# Optional safety check. If set, it must match the derived address.
IOTA_SPONSOR_ADDRESS=0xsponsor_address

# Configure the single sponsored Move call this MVP backend supports.
IOTA_SPONSORED_ACTION_TARGET=0xrpackage::module_name::function_name

# Optional type arguments for the configured Move call. CSV or JSON array are both accepted.
IOTA_SPONSORED_ACTION_TYPE_ARGUMENTS=0x2::iota::IOTA

# Optional gas controls.
IOTA_SPONSOR_MAX_GAS_COINS=10
